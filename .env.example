# Faceless Content Toolkit secure provider router
# Copy this file to .env. Never commit .env.

# Local server settings
FCT_HOST=127.0.0.1
FCT_PORT=3737
# Optional extra local token. Leave blank unless you want the browser UI to send X-FCT-Token manually.
# FCT_LOCAL_TOKEN=

# Anthropic API preset
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/messages

# OpenAI API preset
# OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_RESPONSES_URL=https://api.openai.com/v1/responses

# 9router preset (OpenAI chat-compatible, Bearer auth)
# NINE_ROUTER_API_KEY=...
NINE_ROUTER_MODEL=gpt-4o
NINE_ROUTER_CHAT_URL=https://api.9router.cc/v1/chat/completions
NINE_ROUTER_AUTH_SCHEME=bearer

# OpenCode Zen preset
# Get key from OpenCode Zen. OPENCODE_API_KEY can be shared by Zen/Go if your account uses one key.
# OPENCODE_ZEN_API_KEY=...
OPENCODE_ZEN_MODEL=deepseek-v4-pro
OPENCODE_ZEN_CHAT_URL=https://opencode.ai/zen/v1/chat/completions
# For Anthropic-compatible Zen models such as qwen3.7-plus, use:
# OPENCODE_ZEN_MODEL=qwen3.7-plus
# OPENCODE_ZEN_CHAT_URL=https://opencode.ai/zen/v1/messages
# OPENCODE_ZEN_PROTOCOL=anthropic_compatible
# OPENCODE_ZEN_AUTH_SCHEME=x-api-key

# OpenCode Go preset
# OPENCODE_GO_API_KEY=...
OPENCODE_GO_MODEL=deepseek-v4-flash
OPENCODE_GO_CHAT_URL=https://opencode.ai/zen/go/v1/chat/completions
# For Anthropic-compatible Go models such as qwen3.7-plus or minimax-m3, use:
# OPENCODE_GO_MODEL=qwen3.7-plus
# OPENCODE_GO_CHAT_URL=https://opencode.ai/zen/go/v1/messages
# OPENCODE_GO_PROTOCOL=anthropic_compatible
# OPENCODE_GO_AUTH_SCHEME=x-api-key

# Neuralwatt preset
# NEURALWATT_API_KEY=...
NEURALWATT_MODEL=Qwen/Qwen3-Coder-480B-A35B-Instruct
NEURALWATT_CHAT_URL=https://api.neuralwatt.com/v1/chat/completions

# Custom OpenAI-compatible preset
# CUSTOM_API_KEY=...
# CUSTOM_MODEL=...
# CUSTOM_CHAT_URL=https://your-provider.example/v1/chat/completions
# CUSTOM_AUTH_SCHEME=bearer

# Codex OAuth preset
# 1) Install OpenAI Codex CLI
# 2) Run: codex login
# 3) Set this true and start the router
CODEX_OAUTH_ENABLED=false
CODEX_MODEL=gpt-5-codex
CODEX_BIN=codex
